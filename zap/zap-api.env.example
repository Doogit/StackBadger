# ZAP Automation Framework — environment variables
# These values are injected automatically by run.sh from discovered/FAPI-acquired
# values. This file exists only as reference for standalone ZAP usage.
#
# NEVER commit zap-api.env with real tokens.

# ── Target ────────────────────────────────────────────────────────────────────

# Base URL of the environment to scan. No trailing slash.
# Injected by run.sh from the target_url argument.
TARGET_BASE_URL=https://example.com

# ── Auth (injected by run.sh via FAPI sign-in) ────────────────────────────────

# A valid Clerk JWT, automatically acquired and refreshed by run.sh.
# When running ZAP standalone, obtain from the auth adapter:
#   python -c "from auth.clerk import ...; print(adapter.get_token('user_a'))"
JWT_TOKEN=

# ── Supabase (injected by run.sh via bundle discovery) ────────────────────────

# Supabase anon key — auto-discovered from the target site's JS bundle.
SUPABASE_ANON_KEY=

# Supabase project REST URL — auto-discovered from the target site's JS bundle.
SUPABASE_PROJECT_URL=

# ── Report output ─────────────────────────────────────────────────────────────

# Host-side directory for ZAP reports.
REPORT_DIR=/zap/reports

# ── Standalone Usage ────────────────────────────────────���─────────────────────
# Normally, just use run.sh and ZAP is handled automatically:
#   ./run.sh https://example.com
#
# For standalone ZAP (fill values above first):
#   docker run --rm \
#     --env-file zap/zap-api.env \
#     -v "$(pwd)/zap:/zap/wrk:ro" \
#     -v "${REPORT_DIR:-/tmp/zap-reports}:/zap/reports" \
#     ghcr.io/zaproxy/zaproxy:stable \
#     zap.sh -cmd -autorun /zap/wrk/automation-plan.yaml
#
# Risk codes: 0=INFO  1=LOW  2=MEDIUM  3=HIGH
