{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(.venv\\Scripts\\python.exe -m pytest tests/*)",
      "Bash(python -m pytest tests/*)",
      "Bash(python3 -m pytest tests/*)",
      "Bash(.venv\\Scripts\\python.exe discover.py:*)",
      "Bash(python discover.py:*)",
      "Bash(python -m reports.scrub:*)",
      "Bash(python -m reports.aggregate:*)",
      "Bash(python -m zap.build_runtime_plan)",
      "Bash(.venv\\Scripts\\python.exe -c:*)",
      "Bash(pip install -e .:*)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git check-ignore:*)",
      "Bash(git branch:*)"
    ],
    "ask": [
      "Bash(bash run.sh:*)",
      "Bash(./run.sh:*)",
      "Bash(sh run.sh:*)",
      "Bash(docker run:*)",
      "Bash(docker pull:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./AUTHORIZATION.md)",
      "Read(./roe/**)"
    ]
  }
}
