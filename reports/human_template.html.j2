<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Security Report — {{ site_name }}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <style>
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f8f9fa; }
    .badge-CRITICAL { background-color: #6f42c1; color: #fff; }
    .badge-HIGH     { background-color: #dc3545; color: #fff; }
    .badge-MEDIUM   { background-color: #fd7e14; color: #fff; }
    .badge-LOW      { background-color: #0d6efd; color: #fff; }
    .badge-INFO     { background-color: #6c757d; color: #fff; }
    .source-badge   { font-size: 0.7rem; vertical-align: middle; }
    .finding-card   { border-left: 4px solid #dee2e6; }
    .finding-card.HIGH, .finding-card.CRITICAL { border-left-color: #dc3545; }
    .finding-card.MEDIUM { border-left-color: #fd7e14; }
    .finding-card.LOW    { border-left-color: #0d6efd; }
    .finding-card.INFO   { border-left-color: #6c757d; }
    .coverage-matrix td, .coverage-matrix th { font-size: 0.75rem; white-space: nowrap; }
    .hit { background-color: #dc354520; }
    pre { background: #212529; color: #f8f9fa; padding: 1rem; border-radius: 4px;
          font-size: 0.8rem; max-height: 300px; overflow: auto; }
    .top3-card { border: 2px solid #dc3545; }
  </style>
</head>
<body>
<div class="container py-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">Security Report</h1>
      <small class="text-muted">{{ site_name }} &mdash; Generated {{ generated_at }}</small>
    </div>
    <span class="badge bg-secondary">{{ total }} finding{{ 's' if total != 1 else '' }}</span>
  </div>

  <!-- Executive Summary -->
  <div class="card mb-4">
    <div class="card-header bg-dark text-white fw-bold">Executive Summary</div>
    <div class="card-body">
      <div class="row g-3 mb-3">
        {% for sev, color in [('CRITICAL','purple'),('HIGH','danger'),('MEDIUM','warning'),('LOW','primary'),('INFO','secondary')] %}
        <div class="col-auto">
          <div class="border rounded p-2 text-center" style="min-width:80px">
            <div class="h4 mb-0 text-{{ color if color != 'purple' else 'dark' }}">{{ counts[sev] }}</div>
            <small class="text-muted">{{ sev }}</small>
          </div>
        </div>
        {% endfor %}
      </div>

      {% if top3 %}
      <h6 class="fw-bold">Top 3 to fix first</h6>
      <div class="row g-2">
        {% for f in top3 %}
        <div class="col-md-4">
          <div class="card top3-card h-100">
            <div class="card-body py-2 px-3">
              <span class="badge badge-{{ f.severity }} mb-1">{{ f.severity }}</span>
              <div class="fw-semibold" style="font-size:0.85rem">{{ f.title }}</div>
              <small class="text-muted">{{ f.endpoint or 'n/a' }}</small>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <p class="text-success mb-0">No findings — all tests passed and no ZAP alerts detected.</p>
      {% endif %}
    </div>
  </div>

  <!-- Findings -->
  {% if findings %}
  <h5 class="mb-3">Findings</h5>
  {% for f in findings %}
  <div class="card mb-3 finding-card {{ f.severity }}">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <span class="badge badge-{{ f.severity }} me-2">{{ f.severity }}</span>
        <strong>{{ f.id }}</strong> &mdash; {{ f.title }}
      </div>
      <div>
        <span class="badge bg-light text-dark source-badge me-1">{{ f.source | upper }}</span>
        {% if f.endpoint %}
        <code style="font-size:0.8rem">{{ f.method }} {{ f.endpoint }}</code>
        {% endif %}
      </div>
    </div>
    <div class="card-body">

      <div class="mb-3">
        <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.7rem;letter-spacing:.05em">What happened</h6>
        <p class="mb-0">{{ f.description or 'No description available.' }}</p>
      </div>

      <div class="mb-3">
        <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.7rem;letter-spacing:.05em">Why it matters</h6>
        <p class="mb-0">{{ f.why_it_matters }}</p>
      </div>

      <div class="mb-3">
        <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.7rem;letter-spacing:.05em">How to fix</h6>
        <p class="mb-0">{{ f.remediation_plan }}</p>
      </div>

      {% if f.affected_files %}
      <div class="mb-3">
        <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.7rem;letter-spacing:.05em">Affected files</h6>
        <ul class="mb-0">
          {% for af in f.affected_files %}
          <li><code>{{ af }}</code></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <div class="mb-2">
        <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.7rem;letter-spacing:.05em">Verify fix</h6>
        <code style="font-size:0.8rem">{{ f.test_to_verify }}</code>
      </div>

      <!-- Collapsible evidence -->
      {% set ev = f.evidence %}
      {% if ev and (ev.request or ev.response) %}
      <div class="mt-3">
        <a class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse"
           href="#ev-{{ f.id | replace('-','_') }}" role="button">
          Show evidence
        </a>
        <div class="collapse mt-2" id="ev-{{ f.id | replace('-','_') }}">
          {% if ev.request %}
          <h6 class="mt-2 mb-1" style="font-size:0.8rem">Request</h6>
          <pre>{{ ev.request | tojson(indent=2) }}</pre>
          {% endif %}
          {% if ev.response %}
          <h6 class="mt-2 mb-1" style="font-size:0.8rem">Response</h6>
          <pre>{{ ev.response | tojson(indent=2) }}</pre>
          {% endif %}
        </div>
      </div>
      {% endif %}

    </div>
  </div>
  {% endfor %}
  {% else %}
  <div class="alert alert-success">No findings — all tests passed and no ZAP alerts were raised.</div>
  {% endif %}

  <!-- Coverage Matrix -->
  {% if matrix %}
  <div class="card mt-4">
    <div class="card-header bg-dark text-white fw-bold">Coverage Matrix</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-bordered coverage-matrix mb-0">
          <thead class="table-dark">
            <tr>
              <th>Endpoint</th>
              {% for cat in categories %}
              <th title="{{ cat }}">{{ cat | replace('_',' ') | truncate(10, True, '') }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for row in matrix %}
            <tr>
              <td><code>{{ row.endpoint }}</code></td>
              {% for cat in categories %}
              <td class="{{ 'hit' if row.categories.get(cat) else '' }}" title="{{ cat }}">
                {{ '!' if row.categories.get(cat) else '' }}
              </td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <small class="text-muted px-3 pb-2 d-block">! = finding exists for this endpoint/category pair</small>
    </div>
  </div>
  {% endif %}

  <!-- Provider Layer Findings -->
  {% if provider_findings %}
  <div class="card mt-4">
    <div class="card-header bg-dark text-white fw-bold">Provider Layer Findings</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-bordered mb-0">
          <thead class="table-dark">
            <tr>
              <th>Provider</th>
              <th>Layer</th>
              <th>Test Module</th>
              <th>Severity</th>
              <th>Finding</th>
            </tr>
          </thead>
          <tbody>
            {% for f in provider_findings %}
            <tr>
              <td>{{ f.category | replace('_', ' ') | title }}</td>
              <td>{{ provider_layers.get(f.category, 'unknown') }}</td>
              <td><code>{{ provider_modules.get(f.category, 'unknown') }}</code></td>
              <td><span class="badge badge-{{ f.severity }}">{{ f.severity }}</span></td>
              <td>{{ f.title }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  {% endif %}

  <footer class="mt-4 text-center text-muted small">
    Report generated {{ generated_at }} &mdash; {{ site_name }} pentest harness
  </footer>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmMQHxDhGaBvXc2AIAIABJnSfXsd"
        crossorigin="anonymous"></script>
</body>
</html>
